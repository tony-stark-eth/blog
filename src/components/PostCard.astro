---
import TagList from './TagList.astro';
import type { Locale } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  locale: Locale;
}

const { title, description, date, tags, slug, locale } = Astro.props;
const t = useTranslations(locale);

const postHref = locale === 'de' ? `/de/blog/${slug}/` : `/blog/${slug}/`;

const formattedDate = date.toLocaleDateString(locale === 'de' ? 'de-DE' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border border-gray-200 dark:border-gray-800 rounded-xl p-5 sm:p-6 hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-sm transition-all bg-white dark:bg-gray-900/50">
  <a href={postHref} class="block no-underline">
    <h2 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-gray-100 group-hover:text-brand-500 dark:group-hover:text-brand-500 transition-colors mb-2 leading-snug">
      {title}
    </h2>
  </a>

  <time
    datetime={date.toISOString()}
    class="text-xs text-gray-500 dark:text-gray-400 mb-3 block"
  >
    {formattedDate}
  </time>

  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 line-clamp-3 leading-relaxed">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="mb-4">
      <TagList tags={tags} locale={locale} />
    </div>
  )}

  <a
    href={postHref}
    class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors"
    aria-label={`${t('blog.readMore')}: ${title}`}
  >
    {t('blog.readMore')}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </svg>
  </a>
</article>
