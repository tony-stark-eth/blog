---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TagList from '../components/TagList.astro';
import { useTranslations } from '../i18n/ui';
import type { Locale } from '../i18n/ui';
import { getReadingTime } from '../utils/reading-time';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags: string[];
  locale: Locale;
  cover?: { src: string; alt: string };
  translationSlug?: string;
  headings: Heading[];
  body: string;
}

const {
  title,
  description,
  date,
  updated,
  tags,
  locale = 'en',
  cover,
  translationSlug,
  headings,
  body,
} = Astro.props;

const t = useTranslations(locale);
const readingTime = getReadingTime(body);

const canonicalUrl = Astro.url.href;
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : '';

let alternateLocaleUrl: string | undefined;
if (translationSlug) {
  if (locale === 'en') {
    alternateLocaleUrl = `${siteUrl}/de/blog/${translationSlug}/`;
  } else {
    alternateLocaleUrl = `${siteUrl}/blog/${translationSlug}/`;
  }
}

const formattedDate = date.toLocaleDateString(locale === 'de' ? 'de-DE' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updated
  ? updated.toLocaleDateString(locale === 'de' ? 'de-DE' : 'en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: date.toISOString(),
  ...(updated ? { dateModified: updated.toISOString() } : {}),
  author: {
    '@type': 'Person',
    name: 'Kevin Mauel',
    url: 'https://blog.tony-stark.xyz',
  },
  url: canonicalUrl,
  ...(cover ? { image: cover.src } : {}),
  keywords: tags.join(', '),
  inLanguage: locale === 'de' ? 'de-DE' : 'en-US',
};

const hasToC = headings.some((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  ogImage={cover?.src}
  canonicalUrl={canonicalUrl}
  alternateLocaleUrl={alternateLocaleUrl}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
    slot="head"
  />

  <div class:list={['lg:grid lg:gap-12', hasToC && 'lg:grid-cols-[1fr_220px]']}>
    <div>
      <!-- Post header -->
      <header class="mb-8 not-prose">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 leading-tight mb-4">
          {title}
        </h1>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500 dark:text-gray-400 mb-4">
          <time datetime={date.toISOString()}>
            {t('blog.publishedOn')} {formattedDate}
          </time>

          {formattedUpdated && (
            <span>
              · {t('blog.updatedOn')} {formattedUpdated}
            </span>
          )}

          <span>· {readingTime} {t('blog.minuteRead')}</span>
        </div>

        {tags.length > 0 && (
          <TagList tags={tags} locale={locale} />
        )}

        {cover && (
          <div class="mt-6 rounded-xl overflow-hidden">
            <img
              src={cover.src}
              alt={cover.alt}
              class="w-full object-cover max-h-[400px]"
              loading="eager"
            />
          </div>
        )}
      </header>

      <!-- Post body -->
      <article class="prose dark:prose-invert max-w-none prose-pre:font-mono prose-code:font-mono">
        <slot />
      </article>

      <!-- Share section -->
      <footer class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-800 not-prose">
        <ShareButtons title={title} url={canonicalUrl} locale={locale} />
      </footer>
    </div>

    <!-- Table of Contents: renders mobile <details> + desktop sticky aside internally -->
    {hasToC && (
      <div>
        <TableOfContents headings={headings} locale={locale} />
      </div>
    )}
  </div>
</BaseLayout>
