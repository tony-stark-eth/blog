---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => {
    return data.locale === 'de' && !data.draft;
  });

  const enPosts = await getCollection('blog', ({ data }) => {
    return data.locale === 'en';
  });

  const enFilenames = new Set(enPosts.map((p) => p.id.replace(/^en\//, '')));

  return allPosts.map((post) => {
    const filename = post.id.replace(/^de\//, '');
    const slug = filename.replace(/\.mdx?$/, '');
    const hasEnTranslation = enFilenames.has(filename);

    return {
      params: { slug },
      props: {
        post,
        translationSlug: hasEnTranslation ? slug : undefined,
      },
    };
  });
}

type BlogCollection = Awaited<ReturnType<typeof getCollection<'blog'>>>;

interface Props {
  post: BlogCollection[number];
  translationSlug: string | undefined;
}

const { post, translationSlug } = Astro.props;
const { Content, headings } = await render(post);
---

<PostLayout
  locale="de"
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updated={post.data.updated}
  tags={post.data.tags}
  cover={post.data.cover}
  translationSlug={translationSlug}
  headings={headings}
  body={post.body ?? ''}
>
  <Content />
</PostLayout>
